{
  "name": "dasl-tiles-monorepo",
  "private": true,
  "type": "module",
  "description": "Monorepo for the DASL tiles libraries (@dasl/tiles and the @dasl/tile-* packages)",
  "author": "Robin Berjon <robin@berjon.com>",
  "license": "Apache-2.0",
  "workspaces": [
    "tile-lexicon",
    "tile-writer",
    "tile-car-reader",
    "tile-loader",
    "tile-server",
    "atile",
    "tiles"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "pretest": "npm run build",
    "test": "npm test --workspaces --if-present",
    "watch": "node --watch tile-server/dist/server.js webtiles.bast",
    "release": "node scripts/release.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darobin/dasl-tiles.git"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "mocha": true,
      "es2021": true
    },
    "extends": "eslint:recommended",
    "overrides": [],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {}
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^10.4.0",
    "http-server": "^14.1.1",
    "mocha": "^11.7.6",
    "release-it": "^20.2.1",
    "typescript": "^5.7.2"
  }
}
