{
  "name": "@dasl/tile-server",
  "type": "module",
  "version": "1.0.0",
  "description": "Minimal Express server that isolates DASL tiles in their own origin for browser loading",
  "author": "Robin Berjon <robin@berjon.com>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server.js": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "bin": {
    "tiles-loading-server": "dist/server.js"
  },
  "files": [
    "dist",
    "src",
    "public"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "mocha"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darobin/dasl-tiles.git",
    "directory": "tile-server"
  },
  "dependencies": {
    "express": "^5.2.1",
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "mocha": "^11.7.6",
    "supertest": "^7.0.0"
  }
}
