{
  "name": "@dasl/tile-lexicon",
  "type": "module",
  "version": "1.0.0",
  "description": "AT Protocol lexicon, MASL schema, and shared TypeScript types for DASL tiles",
  "author": "Robin Berjon <robin@berjon.com>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
