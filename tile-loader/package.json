{
  "name": "@dasl/tile-loader",
  "type": "module",
  "version": "2.0.0",
  "description": "Browser architecture for safely loading DASL tiles (mothership, shuttle, worker)",
  "author": "Robin Berjon <robin@berjon.com>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./at": {
      "types": "./dist/at.d.ts",
      "import": "./dist/at.js",
      "default": "./dist/at.js"
    },
    "./car": {
      "types": "./dist/car.d.ts",
      "import": "./dist/car.js",
      "default": "./dist/car.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "import": "./dist/memory.js",
      "default": "./dist/memory.js"
    },
    "./content-scheme": {
      "types": "./dist/content-scheme.d.ts",
      "import": "./dist/content-scheme.js",
      "default": "./dist/content-scheme.js"
    },
    "./webxdc": {
      "types": "./dist/webxdc.d.ts",
      "import": "./dist/webxdc.js",
      "default": "./dist/webxdc.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "mocha"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darobin/dasl-tiles.git",
    "directory": "tile-loader"
  },
  "devDependencies": {
    "global-jsdom": "^24.0.0",
    "jsdom": "^24.1.3",
    "mocha": "^11.7.6"
  },
  "dependencies": {
    "@atcute/car": "^6.0.0",
    "@atcute/cid": "^2.4.1",
    "@dasl/tile-lexicon": "^2.0.0",
    "jszip": "^3.10.1",
    "mime": "^4.1.0",
    "smol-toml": "^1.6.1"
  }
}
