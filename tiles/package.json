{
  "name": "@dasl/tiles",
  "type": "module",
  "version": "1.4.0",
  "description": "All-purpose web tiles library (meta-package re-exporting the @dasl/tile-* libraries)",
  "author": "Robin Berjon <robin@berjon.com>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "atile": "dist/bin/atile.js",
    "tiles-loading-server": "dist/bin/tiles-loading-server.js"
  },
  "exports": {
    "./loading-server": {
      "types": "./dist/compat/loading-server.d.ts",
      "import": "./dist/compat/loading-server.js",
      "default": "./dist/compat/loading-server.js"
    },
    "./loader": {
      "types": "./dist/compat/loader.d.ts",
      "import": "./dist/compat/loader.js",
      "default": "./dist/compat/loader.js"
    },
    "./loader/memory": {
      "types": "./dist/compat/loader-memory.d.ts",
      "import": "./dist/compat/loader-memory.js",
      "default": "./dist/compat/loader-memory.js"
    },
    "./loader/at": {
      "types": "./dist/compat/loader-at.d.ts",
      "import": "./dist/compat/loader-at.js",
      "default": "./dist/compat/loader-at.js"
    },
    "./loader/content-scheme": {
      "types": "./dist/compat/loader-content-scheme.d.ts",
      "import": "./dist/compat/loader-content-scheme.js",
      "default": "./dist/compat/loader-content-scheme.js"
    },
    "./loader/car": {
      "types": "./dist/compat/loader-car.d.ts",
      "import": "./dist/compat/loader-car.js",
      "default": "./dist/compat/loader-car.js"
    },
    "./loader/webxdc": {
      "types": "./dist/compat/loader-webxdc.d.ts",
      "import": "./dist/compat/loader-webxdc.js",
      "default": "./dist/compat/loader-webxdc.js"
    },
    "./car-reader": {
      "types": "./dist/compat/car-reader.d.ts",
      "import": "./dist/compat/car-reader.js",
      "default": "./dist/compat/car-reader.js"
    },
    "./writer": {
      "types": "./dist/compat/writer.d.ts",
      "import": "./dist/compat/writer.js",
      "default": "./dist/compat/writer.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darobin/dasl-tiles.git",
    "directory": "tiles"
  },
  "dependencies": {
    "@dasl/atile": "^1.0.0",
    "@dasl/tile-car-reader": "^1.0.0",
    "@dasl/tile-loader": "^1.0.0",
    "@dasl/tile-server": "^1.0.0",
    "@dasl/tile-writer": "^1.0.0"
  }
}
